# Git ignore patterns for posterior-aware-pd-phenotyping

# Data — never commit patient data
data/MDS_UPDRS_Part_III.csv
data/DaTSCAN_SPECT_Analysis.csv
data/FreeSurfer_7_ASEG.csv
data/BioFIND_MDS_UPDRS_Part_III.csv
data/*.csv
data/*.parquet
data/*.xlsx
# Keep the sample directory
!data/sample/

# Results — large output files
# results/ — uncommit sample_outputs
results/sample_outputs
*.pkl
*.pickle

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.env
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# LaTeX build artifacts
*.aux *.log *.out *.toc *.synctex.gz *.blg *.bbl *.fls *.fdb_latexmk

# IDE
.vscode/
.idea/
*.swp
